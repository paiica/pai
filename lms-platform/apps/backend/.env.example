# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://pai_user:pai_password@localhost:5432/pai_lms?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# S3 / Storage
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=xxxxxxxxxxxx
S3_SECRET_ACCESS_KEY=xxxxxxxxxxxx
S3_BUCKET_NAME=pai-lms-assets

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@paii.ca
EMAIL_FROM_NAME=Professional AI Institute

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Admin
SUPER_ADMIN_EMAIL=admin@paii.ca
SUPER_ADMIN_PASSWORD=change_me_before_seed
