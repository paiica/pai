generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["lms"]
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  super_admin
  admin
  professor
  student

  @@schema("lms")
}

enum ApplicationStatus {
  pending_payment
  payment_submitted
  pending_review
  approved
  rejected
  withdrawn

  @@schema("lms")
}

enum EnrollmentStatus {
  active
  completed
  suspended
  expired

  @@schema("lms")
}

enum LessonType {
  video
  reading
  quiz
  assignment
  live_session
  download
  html

  @@schema("lms")
}

enum QuestionType {
  multiple_choice
  true_false
  short_answer

  @@schema("lms")
}

enum SubmissionStatus {
  submitted
  under_review
  graded
  returned

  @@schema("lms")
}

enum ExamAttemptStatus {
  in_progress
  passed
  failed
  abandoned

  @@schema("lms")
}

enum CertificateStatus {
  active
  expired
  revoked
  suspended

  @@schema("lms")
}

enum ExamStatus {
  draft
  published
  archived

  @@schema("lms")
}

enum ExamQuestionType {
  mcq_single
  mcq_multiple
  true_false
  open_short
  open_long
  essay
  fill_blank
  matching
  ordering
  dropdown
  code
  html

  @@schema("lms")
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
  partially_refunded

  @@schema("lms")
}

enum PaymentType {
  enrollment
  retake_fee
  renewal_fee
  corporate_bundle

  @@schema("lms")
}

enum NotificationType {
  application_submitted
  application_approved
  application_rejected
  enrollment_created
  lesson_completed
  module_completed
  course_completed
  exam_passed
  exam_failed
  certificate_issued
  certificate_expiring
  payment_succeeded
  payment_failed
  assignment_submitted
  assignment_graded
  system_announcement

  @@schema("lms")
}

enum CareerStatus {
  professional
  student
  other

  @@schema("lms")
}

enum CertificationLevel {
  pre_certificate
  foundation
  advanced
  executive
  specialist

  @@schema("lms")
}

enum CertificationStatus {
  active
  archived
  coming_soon

  @@schema("lms")
}

enum CourseStatus {
  draft
  active
  archived

  @@schema("lms")
}

enum CourseLevel {
  beginner
  intermediate
  advanced

  @@schema("lms")
}

// ─────────────────────────────────────────────
// CORE IDENTITY
// ─────────────────────────────────────────────

model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  email_verified             Boolean   @default(false)
  email_verify_token            String?
  email_verify_token_expires_at DateTime?
  pending_email                 String?
  email_change_token_hash    String?   @unique
  email_change_expires_at    DateTime?
  password_hash              String
  role               Role      @default(student)
  is_active          Boolean   @default(true)
  last_login_at      DateTime?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  profile             Profile?
  refresh_tokens      RefreshToken[]
  applications        Application[]
  enrollments         Enrollment[]
  lesson_progress     LessonProgress[]
  exam_attempts       ExamAttempt[]
  certificates        Certificate[]
  payments            Payment[]
  notifications       Notification[]
  audit_logs          AuditLog[]
  professor_courses   CourseInstructor[]
  course_teaching     CourseTeacher[]
  course_enrollments  CourseEnrollment[]
  password_resets     PasswordReset[]
  uploaded_files      UploadedFile[]
  submissions              AssignmentSubmission[] @relation("student_submissions")
  graded_submissions       AssignmentSubmission[] @relation("graded_submissions")
  application_documents    ApplicationDocument[]
  exam_bookings            ExamBooking[]

  @@index([email])
  @@map("users")
  @@schema("lms")
}

model Profile {
  id           String       @id @default(uuid())
  user_id      String       @unique
  user         User         @relation(fields: [user_id], references: [id], onDelete: Cascade)

  first_name   String
  last_name    String
  display_name String?
  avatar_url   String?
  bio          String?
  phone        String?
  date_of_birth DateTime?
  gender       String?
  country      String?
  timezone     String       @default("America/Toronto")
  language     String       @default("en")

  career_status    CareerStatus?
  job_title        String?
  company          String?
  industry         String?
  years_experience Int?
  linkedin_url     String?

  university      String?
  degree_program  String?
  graduation_year Int?

  nationality        String?
  pai_id             String?  @unique
  education_entries  Json     @default("[]")
  experience_entries Json     @default("[]")
  addresses          Json     @default("[]")
  resume_url         String?

  email_notifications Boolean @default(true)
  marketing_emails    Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("profiles")
  @@schema("lms")
}

model RefreshToken {
  id          String   @id @default(uuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token_hash  String   @unique
  device_info String?
  ip_address  String?
  is_revoked  Boolean  @default(false)
  expires_at  DateTime
  created_at  DateTime @default(now())

  @@index([user_id])
  @@index([token_hash])
  @@map("refresh_tokens")
  @@schema("lms")
}

model PasswordReset {
  id         String    @id @default(uuid())
  user_id    String
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token_hash String    @unique
  expires_at DateTime
  used_at    DateTime?
  created_at DateTime  @default(now())

  @@index([token_hash])
  @@map("password_resets")
  @@schema("lms")
}

// ─────────────────────────────────────────────
// CERTIFICATIONS & CURRICULUM
// ─────────────────────────────────────────────

model Certification {
  id                   String              @id @default(uuid())
  slug                 String              @unique
  acronym              String              @unique
  title                String
  level                CertificationLevel
  status               CertificationStatus @default(active)
  badge_icon           String              @default("🎓")
  badge_image_url      String?
  price                Decimal             @db.Decimal(10, 2)
  stripe_price_id      String?

  description          String
  long_description     String
  learning_outcomes    String[]
  target_audience      String[]

  duration_weeks        Int
  total_lessons         Int     @default(0)
  total_hours           Decimal @db.Decimal(5, 1) @default(0)
  passing_score         Int     @default(70)
  exam_duration_minutes Int     @default(90)
  exam_questions_count  Int     @default(75)
  validity_years        Int     @default(2)
  max_retakes_included  Int     @default(2)
  retake_fee            Decimal @db.Decimal(10, 2) @default(99.00)

  curriculum_overview     Json     @default("[]")
  faqs_json               Json     @default("[]")
  marketing_meta          Json     @default("{}")
  testimonials            Json     @default("[]")
  skills                  String[] @default([])
  related_slugs           String[] @default([])
  certificate_preview_url String   @default("")

  min_years_experience  Int?
  min_training_hours    Int?

  sort_order Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  modules              Module[]
  applications         Application[]
  enrollments          Enrollment[]
  certificates         Certificate[]
  exam_banks           ExamBank[]
  exam_sessions        ExamSession[]
  instructors          CourseInstructor[]
  faqs                 CourseFAQ[]
  prep_courses         Course[]
  structured_exams     StructuredExam[]
  course_recommendations CourseCertRecommendation[]

  @@index([slug])
  @@index([status])
  @@map("certifications")
  @@schema("lms")
}

model Module {
  id               String         @id @default(uuid())
  certification_id String?
  certification    Certification? @relation(fields: [certification_id], references: [id], onDelete: Cascade)
  course_id        String?
  course           Course?        @relation(fields: [course_id], references: [id], onDelete: Cascade)

  title          String
  description    String?
  sort_order     Int
  duration_hours Decimal @db.Decimal(5, 1) @default(0)
  is_published   Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  lessons Lesson[]

  @@index([certification_id, sort_order])
  @@index([course_id, sort_order])
  @@map("modules")
  @@schema("lms")
}

model Lesson {
  id        String @id @default(uuid())
  module_id String
  module    Module @relation(fields: [module_id], references: [id], onDelete: Cascade)

  title            String
  description      String?
  type             LessonType
  sort_order       Int
  duration_minutes Int     @default(10)
  is_published     Boolean @default(false)
  is_free_preview  Boolean @default(false)

  video_url          String?
  video_duration_sec Int?
  content_body       String?  @db.Text
  download_url       String?
  allow_download     Boolean  @default(true)
  external_url       String?

  // Quiz settings
  passing_score      Int?    @default(70)
  max_attempts       Int?    @default(3)
  time_limit_minutes Int?

  // Assignment settings
  due_date             DateTime?
  max_score            Int?     @default(100)
  allow_text_response  Boolean  @default(true)
  text_word_limit      Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  progress                LessonProgress[]
  quiz_questions          QuizQuestion[]
  resources               LessonResource[]
  assignment_submissions  AssignmentSubmission[]
  uploaded_files          UploadedFile[]

  @@index([module_id, sort_order])
  @@map("lessons")
  @@schema("lms")
}

model LessonResource {
  id        String  @id @default(uuid())
  lesson_id String
  lesson    Lesson  @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  title     String
  url       String
  file_type String?
  created_at DateTime @default(now())

  @@map("lesson_resources")
  @@schema("lms")
}

model QuizQuestion {
  id            String       @id @default(uuid())
  lesson_id     String
  lesson        Lesson       @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  question_text String
  question_type QuestionType @default(multiple_choice)
  options       Json
  correct_index Int
  explanation   String?
  points        Int          @default(1)
  sort_order    Int          @default(0)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt

  @@index([lesson_id])
  @@map("quiz_questions")
  @@schema("lms")
}

model ExamBank {
  id               String        @id @default(uuid())
  certification_id String
  certification    Certification @relation(fields: [certification_id], references: [id], onDelete: Cascade)
  question_text    String
  options          Json
  correct_index    Int
  explanation      String?
  topic_tag        String?
  difficulty       Int     @default(2)
  is_active        Boolean @default(true)
  created_by       String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@index([certification_id, is_active])
  @@map("exam_bank")
  @@schema("lms")
}

model CourseInstructor {
  id               String        @id @default(uuid())
  certification_id String
  certification    Certification @relation(fields: [certification_id], references: [id])
  user_id          String
  user             User          @relation(fields: [user_id], references: [id])
  is_lead          Boolean  @default(false)
  assigned_at      DateTime @default(now())

  @@unique([certification_id, user_id])
  @@map("course_instructors")
  @@schema("lms")
}

model CourseFAQ {
  id               String        @id @default(uuid())
  certification_id String
  certification    Certification @relation(fields: [certification_id], references: [id], onDelete: Cascade)
  question         String
  answer           String
  sort_order       Int      @default(0)
  created_at       DateTime @default(now())

  @@map("course_faqs")
  @@schema("lms")
}

// ─────────────────────────────────────────────
// STANDALONE COURSES (purchasable prep content)
// ─────────────────────────────────────────────

model Course {
  id                   String       @id @default(uuid())
  slug                 String       @unique
  title                String
  subtitle             String?
  description          String?
  price                Decimal      @db.Decimal(10, 2) @default(0)
  status               CourseStatus @default(draft)
  thumbnail_url        String?
  preview_video_url    String?
  level                CourseLevel  @default(beginner)
  duration_hours       Decimal      @db.Decimal(5, 1) @default(0)
  total_lessons        Int          @default(0)

  // Optional link to the certification this course prepares for
  certification_id     String?
  certification        Certification? @relation(fields: [certification_id], references: [id], onDelete: SetNull)

  is_featured  Boolean  @default(false)
  sort_order   Int      @default(0)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  modules          Module[]
  instructors      CourseTeacher[]
  enrollments      CourseEnrollment[]
  cert_recommendations CourseCertRecommendation[]

  @@index([slug])
  @@index([status])
  @@map("courses")
  @@schema("lms")
}

model CourseTeacher {
  id          String   @id @default(uuid())
  course_id   String
  course      Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)
  user_id     String
  user        User     @relation(fields: [user_id], references: [id])
  is_lead     Boolean  @default(false)
  assigned_at DateTime @default(now())

  @@unique([course_id, user_id])
  @@map("course_teachers")
  @@schema("lms")
}

model CourseEnrollment {
  id                  String   @id @default(uuid())
  user_id             String
  user                User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  course_id           String
  course              Course   @relation(fields: [course_id], references: [id])
  progress_percentage Int      @default(0)
  enrolled_at         DateTime @default(now())
  completed_at        DateTime?

  stripe_payment_intent_id   String?
  amount_paid                Decimal? @db.Decimal(10, 2)

  @@unique([user_id, course_id])
  @@index([user_id])
  @@index([course_id])
  @@map("course_enrollments")
  @@schema("lms")
}

model CourseCertRecommendation {
  course_id        String
  course           Course        @relation(fields: [course_id], references: [id], onDelete: Cascade)
  certification_id String
  certification    Certification @relation(fields: [certification_id], references: [id], onDelete: Cascade)

  @@id([course_id, certification_id])
  @@map("course_cert_recommendations")
  @@schema("lms")
}

// ─────────────────────────────────────────────
// FILE UPLOADS
// ─────────────────────────────────────────────

model UploadedFile {
  id            String  @id @default(uuid())
  owner_id      String
  owner         User    @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  lesson_id     String?
  lesson        Lesson? @relation(fields: [lesson_id], references: [id], onDelete: SetNull)

  filename      String
  original_name String
  size          Int
  mime_type     String
  s3_key        String
  url           String
  purpose       String  @default("content")

  created_at    DateTime @default(now())

  @@index([owner_id])
  @@index([lesson_id])
  @@map("uploaded_files")
  @@schema("lms")
}

// ─────────────────────────────────────────────
// APPLICATIONS
// ─────────────────────────────────────────────

model Application {
  id               String            @id @default(uuid())
  user_id          String
  user             User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  certification_id String
  certification    Certification     @relation(fields: [certification_id], references: [id])
  status           ApplicationStatus @default(pending_payment)

  full_name       String
  email           String
  phone           String?
  date_of_birth   DateTime?
  gender          String?
  country         String?
  career_status   CareerStatus?
  job_title       String?
  company         String?
  years_experience Int?
  training_hours  Int?
  linkedin_url    String?
  university      String?
  degree_program  String?
  graduation_year Int?
  motivation      String?
  how_heard       String?

  education_entries  Json     @default("[]")
  experience_entries Json     @default("[]")

  documents_requested       Boolean   @default(false)
  documents_request_message String?
  documents_requested_at    DateTime?

  stripe_payment_intent_id   String?
  stripe_checkout_session_id String?
  amount_paid                Decimal?      @db.Decimal(10, 2)
  payment_status             PaymentStatus @default(pending)
  paid_at                    DateTime?
  promo_code                 String?

  reviewed_by      String?
  reviewed_at      DateTime?
  rejection_reason String?

  stripe_refund_id String?
  refunded_at      DateTime?
  refund_amount    Decimal? @db.Decimal(10, 2)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  enrollment Enrollment?
  documents  ApplicationDocument[]

  @@unique([user_id, certification_id])
  @@index([status])
  @@index([user_id])
  @@map("applications")
  @@schema("lms")
}

model ApplicationDocument {
  id             String      @id @default(uuid())
  application_id String
  application    Application @relation(fields: [application_id], references: [id], onDelete: Cascade)
  user_id        String
  user           User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  file_url      String
  s3_key        String
  file_name     String
  mime_type     String?
  file_size     Int?
  uploaded_at   DateTime @default(now())

  @@index([application_id])
  @@map("application_documents")
  @@schema("lms")
}

// ─────────────────────────────────────────────
// ENROLLMENTS & PROGRESS
// ─────────────────────────────────────────────

model Enrollment {
  id               String           @id @default(uuid())
  user_id          String
  user             User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  certification_id String
  certification    Certification    @relation(fields: [certification_id], references: [id])
  application_id   String?          @unique
  application      Application?     @relation(fields: [application_id], references: [id])
  status           EnrollmentStatus @default(active)
  progress_percentage Int           @default(0)
  enrolled_at      DateTime         @default(now())
  completed_at     DateTime?
  expires_at       DateTime?
  last_accessed_at DateTime?

  lesson_progress         LessonProgress[]
  exam_attempts           ExamAttempt[]
  exam_bookings           ExamBooking[]
  certificate             Certificate?
  assignment_submissions  AssignmentSubmission[]

  @@unique([user_id, certification_id])
  @@index([user_id])
  @@index([certification_id])
  @@map("enrollments")
  @@schema("lms")
}

model LessonProgress {
  id            String     @id @default(uuid())
  user_id       String
  user          User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  enrollment_id String
  enrollment    Enrollment @relation(fields: [enrollment_id], references: [id], onDelete: Cascade)
  lesson_id     String
  lesson        Lesson     @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  completed     Boolean    @default(false)
  completed_at  DateTime?
  watch_seconds Int        @default(0)
  quiz_score    Int?
  quiz_passed   Boolean?
  quiz_attempts Int        @default(0)
  last_position Int        @default(0)
  started_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  @@unique([user_id, lesson_id])
  @@index([enrollment_id])
  @@map("lesson_progress")
  @@schema("lms")
}

// ─────────────────────────────────────────────
// ASSIGNMENT SUBMISSIONS
// ─────────────────────────────────────────────

model AssignmentSubmission {
  id            String           @id @default(uuid())
  lesson_id     String
  lesson        Lesson           @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  user_id       String
  user          User             @relation("student_submissions", fields: [user_id], references: [id], onDelete: Cascade)
  enrollment_id String
  enrollment    Enrollment       @relation(fields: [enrollment_id], references: [id], onDelete: Cascade)

  file_url      String?
  file_name     String?
  file_size     Int?
  text_content  String?          @db.Text

  status        SubmissionStatus @default(submitted)
  submitted_at  DateTime         @default(now())
  updated_at    DateTime         @updatedAt

  grade         Float?
  max_grade     Float            @default(100)
  feedback      String?          @db.Text
  graded_by     String?
  grader        User?            @relation("graded_submissions", fields: [graded_by], references: [id], onDelete: SetNull)
  graded_at     DateTime?

  @@unique([lesson_id, user_id])
  @@index([enrollment_id])
  @@index([lesson_id])
  @@map("assignment_submissions")
  @@schema("lms")
}

// ─────────────────────────────────────────────
// EXAMS & CERTIFICATES
// ─────────────────────────────────────────────

model ExamAttempt {
  id            String            @id @default(uuid())
  user_id       String
  user          User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  enrollment_id String
  enrollment    Enrollment        @relation(fields: [enrollment_id], references: [id], onDelete: Cascade)
  attempt_number Int              @default(1)
  status        ExamAttemptStatus @default(in_progress)

  started_at         DateTime @default(now())
  submitted_at       DateTime?
  time_limit_seconds Int?
  time_used_seconds  Int?

  total_questions  Int
  correct_answers  Int     @default(0)
  score_percentage Decimal? @db.Decimal(5, 2)
  passing_score    Int
  passed           Boolean?

  answers            Json?
  topic_breakdown    Json?
  proctor_session_id String?

  created_at DateTime @default(now())

  attempt_sections ExamAttemptSection[]
  student_answers  StudentAnswer[]

  @@index([enrollment_id])
  @@index([user_id])
  @@map("exam_attempts")
  @@schema("lms")
}

model ExamSession {
  id               String        @id @default(uuid())
  certification_id String
  certification    Certification @relation(fields: [certification_id], references: [id], onDelete: Cascade)
  structured_exam_id String?
  structured_exam    StructuredExam? @relation(fields: [structured_exam_id], references: [id], onDelete: SetNull)
  title            String?
  scheduled_at     DateTime
  duration_minutes Int           @default(90)
  max_seats        Int?
  meeting_link              String?
  notes                     String?
  is_active                 Boolean  @default(true)
  allow_late_cancellation   Boolean  @default(false)
  created_by                String
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  bookings ExamBooking[]

  @@index([certification_id])
  @@index([scheduled_at])
  @@map("exam_sessions")
  @@schema("lms")
}

model ExamBooking {
  id              String      @id @default(uuid())
  user_id         String
  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  exam_session_id String
  exam_session    ExamSession @relation(fields: [exam_session_id], references: [id], onDelete: Cascade)
  enrollment_id   String
  enrollment      Enrollment  @relation(fields: [enrollment_id], references: [id], onDelete: Cascade)
  status          String      @default("confirmed")
  booked_at       DateTime    @default(now())
  cancelled_at    DateTime?

  @@unique([user_id, exam_session_id])
  @@index([user_id])
  @@index([exam_session_id])
  @@map("exam_bookings")
  @@schema("lms")
}

// ─────────────────────────────────────────────
// STRUCTURED EXAM SYSTEM
// ─────────────────────────────────────────────

model StructuredExam {
  id               String        @id @default(uuid())
  certification_id String
  certification    Certification @relation(fields: [certification_id], references: [id], onDelete: Cascade)
  title            String
  description      String?
  status           ExamStatus    @default(draft)
  version          String?
  passing_score    Int           @default(70)
  created_by       String
  created_at       DateTime      @default(now())
  updated_at       DateTime      @updatedAt

  sections      ExamSection[]
  exam_sessions ExamSession[]

  @@index([certification_id])
  @@map("structured_exams")
  @@schema("lms")
}

model ExamSection {
  id                 String         @id @default(uuid())
  exam_id            String
  exam               StructuredExam @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  title              String
  description        String?
  sort_order         Int            @default(0)
  time_limit_minutes Int?
  instructions       String?        @db.Text
  is_required        Boolean        @default(true)
  passing_score      Int            @default(70)
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt

  questions         ExamQuestion[]
  instruction_pages SectionInstructionPage[]
  attempt_sections  ExamAttemptSection[]

  @@index([exam_id, sort_order])
  @@map("exam_sections")
  @@schema("lms")
}

model SectionInstructionPage {
  id         String      @id @default(uuid())
  section_id String
  section    ExamSection @relation(fields: [section_id], references: [id], onDelete: Cascade)
  title      String?
  content    String      @db.Text
  sort_order Int         @default(0)
  created_at DateTime    @default(now())
  updated_at DateTime    @updatedAt

  @@index([section_id])
  @@map("section_instruction_pages")
  @@schema("lms")
}

model ExamQuestion {
  id            String           @id @default(uuid())
  section_id    String
  section       ExamSection      @relation(fields: [section_id], references: [id], onDelete: Cascade)
  type          ExamQuestionType @default(mcq_single)
  question_text String           @db.Text
  explanation   String?          @db.Text
  points        Int              @default(1)
  sort_order    Int              @default(0)
  is_required   Boolean          @default(true)
  metadata      Json?
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt

  options QuestionOption[]
  images  QuestionImage[]
  answers StudentAnswer[]

  @@index([section_id, sort_order])
  @@map("exam_questions")
  @@schema("lms")
}

model QuestionOption {
  id          String       @id @default(uuid())
  question_id String
  question    ExamQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)
  text        String
  is_correct  Boolean      @default(false)
  sort_order  Int          @default(0)
  match_text  String?

  @@index([question_id])
  @@map("question_options")
  @@schema("lms")
}

model QuestionImage {
  id          String       @id @default(uuid())
  question_id String
  question    ExamQuestion @relation(fields: [question_id], references: [id], onDelete: Cascade)
  url         String
  alt_text    String?
  caption     String?
  sort_order  Int          @default(0)
  created_at  DateTime     @default(now())

  @@index([question_id])
  @@map("question_images")
  @@schema("lms")
}

model ExamAttemptSection {
  id                String      @id @default(uuid())
  attempt_id        String
  attempt           ExamAttempt @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  section_id        String
  section           ExamSection @relation(fields: [section_id], references: [id])
  status            String      @default("not_started")
  started_at        DateTime?
  submitted_at      DateTime?
  time_used_seconds Int?

  @@unique([attempt_id, section_id])
  @@index([attempt_id])
  @@map("attempt_sections")
  @@schema("lms")
}

model StudentAnswer {
  id                  String       @id @default(uuid())
  attempt_id          String
  attempt             ExamAttempt  @relation(fields: [attempt_id], references: [id], onDelete: Cascade)
  question_id         String
  question            ExamQuestion @relation(fields: [question_id], references: [id])
  selected_option_ids Json?
  answer_text         String?      @db.Text
  answer_json         Json?
  is_correct          Boolean?
  points_awarded      Int?
  answered_at         DateTime     @default(now())

  @@unique([attempt_id, question_id])
  @@index([attempt_id])
  @@map("student_answers")
  @@schema("lms")
}

model SiteSetting {
  key        String   @id
  value      String
  updated_at DateTime @updatedAt

  @@map("site_settings")
  @@schema("lms")
}

model Certificate {
  id               String            @id @default(uuid())
  user_id          String
  user             User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  enrollment_id    String            @unique
  enrollment       Enrollment        @relation(fields: [enrollment_id], references: [id])
  certification_id String
  certification    Certification     @relation(fields: [certification_id], references: [id])

  certificate_number    String            @unique
  status                CertificateStatus @default(active)

  holder_name           String
  certification_title   String
  certification_acronym String
  exam_score            Decimal @db.Decimal(5, 2)

  issued_at         DateTime  @default(now())
  expires_at        DateTime
  revoked_at        DateTime?
  revocation_reason String?

  verification_url  String
  qr_code_url       String?
  pdf_url           String?
  badge_url         String?

  linkedin_added    Boolean  @default(false)
  linkedin_added_at DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([certificate_number])
  @@index([user_id])
  @@map("certificates")
  @@schema("lms")
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id      String @id @default(uuid())
  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  type    PaymentType
  status  PaymentStatus @default(pending)

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("USD")

  stripe_payment_intent_id   String? @unique
  stripe_checkout_session_id String?
  stripe_charge_id           String?
  stripe_receipt_url         String?

  description String?
  metadata    Json?

  refund_amount    Decimal? @db.Decimal(10, 2)
  stripe_refund_id String?
  refunded_at      DateTime?

  succeeded_at   DateTime?
  failed_at      DateTime?
  failure_reason String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([user_id])
  @@index([status])
  @@map("payments")
  @@schema("lms")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id      String           @id @default(uuid())
  user_id String
  user    User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  type    NotificationType
  title   String
  body    String
  data    Json?
  read    Boolean  @default(false)
  read_at DateTime?
  created_at DateTime @default(now())

  @@index([user_id, read])
  @@map("notifications")
  @@schema("lms")
}

// ─────────────────────────────────────────────
// AUDIT & SYSTEM
// ─────────────────────────────────────────────

model AuditLog {
  id          String  @id @default(uuid())
  user_id     String?
  user        User?   @relation(fields: [user_id], references: [id], onDelete: SetNull)
  action      String
  entity_type String?
  entity_id   String?
  old_value   Json?
  new_value   Json?
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())

  @@index([user_id])
  @@index([entity_type, entity_id])
  @@map("audit_logs")
  @@schema("lms")
}

model SystemConfig {
  id          String  @id @default(uuid())
  key         String  @unique
  value       String
  description String?
  updated_by  String?
  updated_at  DateTime @updatedAt
  created_at  DateTime @default(now())

  @@map("system_config")
  @@schema("lms")
}

// ─────────────────────────────────────────────
// CMS — PAGE BLOCKS & NAVIGATION
// ─────────────────────────────────────────────

model PageBlock {
  key        String   @id
  label      String
  is_visible Boolean  @default(true)
  content    Json     @default("{}")
  sort_order Int      @default(0)
  updated_at DateTime @updatedAt

  @@map("page_blocks")
  @@schema("lms")
}

model NavItem {
  id           String    @id @default(uuid())
  label        String
  href         String
  sort_order   Int       @default(0)
  is_visible   Boolean   @default(true)
  open_new_tab Boolean   @default(false)
  parent_id    String?
  parent       NavItem?  @relation("NavItemChildren", fields: [parent_id], references: [id], onDelete: Cascade)
  children     NavItem[] @relation("NavItemChildren")
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt

  @@index([parent_id])
  @@map("nav_items")
  @@schema("lms")
}

model Page {
  id               String   @id @default(uuid())
  slug             String   @unique
  title            String
  content          String   @default("")
  meta_description String   @default("")
  is_published     Boolean  @default(false)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("pages")
  @@schema("lms")
}

model BlogPost {
  id              String    @id @default(uuid())
  slug            String    @unique
  title           String
  excerpt         String    @default("")
  content         String    @default("")
  cover_image_url String    @default("")
  category        String    @default("")
  tags            String[]  @default([])
  author_name     String    @default("")
  author_avatar   String    @default("")
  reading_time    String    @default("")
  is_published    Boolean   @default(false)
  is_featured     Boolean   @default(false)
  published_at    DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@map("blog_posts")
  @@schema("lms")
}

// ─────────────────────────────────────────────
// ONLINE TOOLS
// ─────────────────────────────────────────────

model OnlineTool {
  id                String   @id @default(uuid())
  slug              String   @unique
  title             String
  tagline           String?
  offered_by        String?
  tool_type         String   @default("course")   // course | bundle | subscription | external
  price             Decimal  @db.Decimal(10, 2) @default(0)
  member_price      Decimal? @db.Decimal(10, 2)
  billing_type      String   @default("one_time") // one_time | monthly | annual | free
  short_description String?
  overview          String?
  thumbnail_url     String?
  badge_text        String?
  cta_label         String   @default("Add To Cart")
  cta_url           String?
  features          Json     @default("[]")       // [{title,description}]
  how_it_works      Json     @default("[]")       // [{title,description}]
  status            String   @default("draft")    // draft | active | archived
  sort_order        Int      @default(0)
  course_id         String?
  certification_id  String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("online_tools")
  @@schema("lms")
}

// ─────────────────────────────────────────────
// PROMO CODES
// ─────────────────────────────────────────────

model PromoCode {
  id               String   @id @default(uuid())
  code             String   @unique
  description      String?
  discount_type    String   // "percentage" | "fixed"
  discount_value   Decimal  @db.Decimal(10, 2)
  max_uses         Int?
  used_count       Int      @default(0)
  expires_at       DateTime?
  is_active        Boolean  @default(true)
  course_id        String?
  certification_id String?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  @@map("promo_codes")
  @@schema("lms")
}
