{
  "name": "pai-lms-platform",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "apps/frontend",
    "apps/paiiexams",
    "apps/exam-admin",
    "shared"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=apps/backend",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev:paiiexams": "npm run dev --workspace=apps/paiiexams",
    "dev:exam-admin": "npm run dev --workspace=apps/exam-admin",
    "build:backend": "npm run build --workspace=apps/backend",
    "build:frontend": "npm run build --workspace=apps/frontend",
    "build:paiiexams": "npm run build --workspace=apps/paiiexams",
    "build:exam-admin": "npm run build --workspace=apps/exam-admin",
    "build": "npm run build:backend && npm run build:frontend && npm run build:paiiexams && npm run build:exam-admin",
    "lint": "npm run lint --workspaces",
    "type-check": "npm run type-check --workspaces"
  },
  "devDependencies": {
    "rxjs": "^7.8.2",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "rxjs": "^7.8.2"
  }
}
